# Copy to .env and fill in. These are referenced from config.yml via ${...}.

# Discord bot token: Developer Portal -> your app -> Bot -> Reset Token
DISCORD_TOKEN=

# Linear personal API key: https://linear.app/settings/api
LINEAR_API_KEY=

# Optional overrides
# CONFIG_PATH=./config.yml
# LOG_LEVEL=info          # trace | debug | info | warn | error
# LOG_PRETTY=true         # force pretty logs even with NODE_ENV=production
